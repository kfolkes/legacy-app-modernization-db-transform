{
  "DatabaseProvider": "SqlServer",
  "ConnectionStrings": {
    "CatalogDb": "Server=(localdb)\\MSSQLLocalDB;Database=eShopModernized.CatalogDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "CatalogSettings": {
    "UseMockData": false,
    "UseCustomizationData": false,
    "PicBaseUrl": "/pics/"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
