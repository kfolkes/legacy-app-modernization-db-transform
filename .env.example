# =============================================================================
# App Modernization Lab — Environment Variables
# =============================================================================
# Copy this file to .env and adjust:
#   cp .env.example .env
#
# This file supports BOTH stacks (.NET and Java) and TWO modes per stack:
#
#   1) DEMO mode  — bundled samples in legacy/{dotnet-eshop,java-asset-manager}
#   2) BYO mode   — point LEGACY_DOTNET_PATH or LEGACY_JAVA_PATH at any folder
#
# =============================================================================

# ---------------------------------------------------------------------------
# .NET modernization
# ---------------------------------------------------------------------------
LEGACY_DOTNET_PATH='legacy/dotnet-eshop/eShopLegacyMVCSolution'
MODERNIZED_DOTNET_PATH='modernized/dotnet-eshop'
TARGET_DOTNET_FRAMEWORK='net10.0'

# ---------------------------------------------------------------------------
# Java modernization
# ---------------------------------------------------------------------------
LEGACY_JAVA_PATH='legacy/java-asset-manager'
MODERNIZED_JAVA_PATH='modernized/java-asset-manager'
TARGET_JDK='21'
TARGET_SPRING_BOOT='3.3'

# ---------------------------------------------------------------------------
# Azure deployment targets (used by Phase 8)
# ---------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=''
AZURE_LOCATION='eastus2'
AZURE_RESOURCE_GROUP='rg-appmod-lab'
AZURE_DEPLOYMENT_TARGET='container-apps'   # container-apps | app-service | aks

# ---------------------------------------------------------------------------
# Optional: SQL Server / PostgreSQL for apps that need a database
# ---------------------------------------------------------------------------
SA_PASSWORD='Str0ngP@ssw0rd!'
PG_PASSWORD='Str0ngP@ssw0rd!'
